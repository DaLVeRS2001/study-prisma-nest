// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Home {
  id                Int          @id @default(autoincrement())
  address           String
  numberOfBedrooms  Int          @map("number_of_bedrooms")
  numberOfBathrooms Float        @map("number_of_bathrooms")
  city              String
  listedDate        DateTime     @default(now()) @map("listed_date")
  price             Float
  landSize          Float        @map("land_size")
  propertyType      PropertyType @map("property_type")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  realtorId         Int          @map("realtor_id")

  realtor  User      @relation(fields: [realtorId], references: [id])
  messages Message[]
  images   Image[]

  @@index([realtorId])
}

model Message {
  id        Int    @id @default(autoincrement())
  message   String
  homeId    Int    @map("home_id")
  realtorId Int    @map("realtor_id")
  buyerId   Int    @map("buyer_id")

  home    Home @relation(fields: [homeId], references: [id])
  realtor User @relation("RealtorMessages", fields: [realtorId], references: [id])
  buyer   User @relation("BuyerMessages", fields: [buyerId], references: [id])

  @@index([homeId])
  @@index([realtorId])
  @@index([buyerId])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userType  UserType @map("user_type")

  homes           Home[]
  realtorMessages Message[] @relation("RealtorMessages")
  buyerMessages   Message[] @relation("BuyerMessages")
}

model Image {
  id        Int      @id @default(autoincrement())
  url       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  homeId    Int      @map("home_id")
  home      Home     @relation(fields: [homeId], references: [id])

  @@index([homeId])
}

enum PropertyType {
  RESIDENTIAL
  CONDO
}

enum UserType {
  BUYER
  REALTOR
  ADMIN
}
